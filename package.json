{
  "name": "@minamorl/colimit",
  "version": "0.2.0",
  "description": "Typed groupBy-fold with semilattice merge. Replace ad-hoc Set/Map dedup with composable mergers (G-Set, LWW, max, PN-Counter).",
  "keywords": [
    "groupby",
    "merge",
    "dedup",
    "crdt",
    "semilattice",
    "lww",
    "g-set",
    "pn-counter",
    "fold",
    "typescript",
    "category-theory",
    "kan-extension"
  ],
  "homepage": "https://github.com/minamorl/colimit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minamorl/colimit.git"
  },
  "bugs": {
    "url": "https://github.com/minamorl/colimit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run clean && tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "dev": "vitest",
    "lint": "eslint \"src/**/*.ts\""
  },
  "license": "MIT",
  "packageManager": "pnpm@9.1.1",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
